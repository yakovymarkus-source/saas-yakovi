# ════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in all values
# NEVER commit .env to version control!
# ════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...                            # anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...                    # service role key (KEEP SECRET)

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=64-character-hex-string-here

# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://your-app.netlify.app              # no trailing slash

# ── Payment provider selection ────────────────────────────────────────────────
# To switch providers: change this value + set the matching env vars below.
# Available: grow | stripe
PAYMENT_PROVIDER=grow

# ── Grow / Meshulam (active provider) ────────────────────────────────────────
GROW_API_KEY=f35f9bde-c3cf-3d55-3845-b7fc91009405 # מפתח סליקה מ-Meshulam
GROW_TERMINAL_ID=316302181                          # מספר מסוף
GROW_LINK_EARLY_BIRD=https://pay.grow.link/...     # Early Bird plan payment link
GROW_LINK_PRO=https://pay.grow.link/...            # Pro plan payment link
GROW_LINK_PRO_UPGRADE=https://pay.grow.link/...    # Early Bird → Pro upgrade link

# ── Stripe (available provider — configure to activate) ───────────────────────
STRIPE_SECRET_KEY=sk_live_...                      # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...                    # from Stripe dashboard → Webhooks
STRIPE_PRICE_STARTER=price_...                     # Starter plan monthly price ID
STRIPE_PRICE_PRO=price_...                         # Pro plan monthly price ID
STRIPE_PRICE_AGENCY=price_...                      # Agency plan monthly price ID

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
EMAIL_REPLY_TO=support@yourdomain.com
ADMIN_EMAIL=yakovymarkus@gmail.com

# ── Google OAuth / GA4 / Google Ads ──────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_ADS_DEVELOPER_TOKEN=...                     # from Google Ads API Center

# ── WhatsApp Business ────────────────────────────────────────────────────────
# Switch between providers: meta | twilio
WHATSAPP_PROVIDER=meta

# Meta Cloud API (WHATSAPP_PROVIDER=meta)
WHATSAPP_PHONE_NUMBER_ID=...                       # from Meta Developer Console → WhatsApp → Getting Started
WHATSAPP_ACCESS_TOKEN=EAA...                       # System User permanent token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-secret  # any string you choose — set the same in Meta webhook config

# Twilio (WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886         # Twilio sandbox or approved number

# ── Meta (Facebook) ───────────────────────────────────────────────────────────
META_APP_ID=...                                    # from Meta Developer Console
META_APP_SECRET=...
META_GRAPH_VERSION=v19.0

# ── Meta Pixel + Conversions API (hybrid tracking) ───────────────────────────
META_PIXEL_ID=...                                  # Pixel ID from Meta Events Manager
FB_ACCESS_TOKEN=...                                # System User access token (Meta Business → System Users)
META_API_VERSION=v19.0                             # Conversions API version

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60                                  # requests per window
RATE_LIMIT_WINDOW_SECONDS=60

# ── Caching ───────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=2700
STALE_CACHE_TTL_SECONDS=21600

# ── Internal ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEALTH_SECRET=secret-for-deep-health-check
SYNC_JOB_INTERNAL_SECRET=secret-for-internal-job-trigger
ANALYSIS_VERSION=1.0.0
