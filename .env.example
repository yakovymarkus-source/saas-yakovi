# ════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in all values
# NEVER commit .env to version control!
# ════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...                            # anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...                    # service role key (KEEP SECRET)

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=64-character-hex-string-here

# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://your-app.netlify.app              # no trailing slash

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...                      # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...                    # from Stripe dashboard → Webhooks
STRIPE_PRICE_STARTER=price_...                     # Starter plan monthly price ID
STRIPE_PRICE_PRO=price_...                         # Pro plan monthly price ID
STRIPE_PRICE_AGENCY=price_...                      # Agency plan monthly price ID

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
EMAIL_REPLY_TO=support@yourdomain.com
ADMIN_EMAIL=yakovymarkus@gmail.com

# ── Google OAuth / GA4 / Google Ads ──────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_ADS_DEVELOPER_TOKEN=...                     # from Google Ads API Center

# ── Meta (Facebook) ───────────────────────────────────────────────────────────
META_APP_ID=...                                    # from Meta Developer Console
META_APP_SECRET=...
META_GRAPH_VERSION=v19.0

# ── Meta Pixel + Conversions API (hybrid tracking) ───────────────────────────
META_PIXEL_ID=...                                  # Pixel ID from Meta Events Manager
FB_ACCESS_TOKEN=...                                # System User access token (Meta Business → System Users)
META_API_VERSION=v19.0                             # Conversions API version

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60                                  # requests per window
RATE_LIMIT_WINDOW_SECONDS=60

# ── Caching ───────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=2700
STALE_CACHE_TTL_SECONDS=21600

# ── Internal ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEALTH_SECRET=secret-for-deep-health-check
SYNC_JOB_INTERNAL_SECRET=secret-for-internal-job-trigger
ANALYSIS_VERSION=1.0.0
